{
  "name": "music-scraper",
  "version": "1.0.0",
  "description": "CLI tool to ingest radio playlists and generate weekly analytics reports.",
  "type": "module",
  "bin": {
    "music-scraper": "./src/cli.js"
  },
  "scripts": {
    "api": "node src/cli.js api --config config.yaml --db yrpa.sqlite --port 8787",
    "daily": "node src/cli.js daily-job --config config.yaml --make-report",
    "evaluate:today": "node src/cli.js evaluate-daily --config config.yaml",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "luxon": "^3.6.1",
    "node-cron": "^4.2.1",
    "pino": "^9.6.0",
    "undici": "^7.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vitest": "^3.0.5"
  }
}
